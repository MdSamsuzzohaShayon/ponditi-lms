{
  "name": "ponditi-backend-api",
  "version": "1.0.0",
  "description": "node express crud api with sequelize",
  "main": "server.js",
  "scripts": {
    "dev": "env NODE_ENV=development nodemon -L server.js",
    "start": "env NODE_ENV=production node server.js",
    "swagger-autogen": "node swagger.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "seeder": "npx sequelize-cli db:seed:all --config ./config/config.js"
  },
  "keywords": [
    "node",
    "express",
    "mysql"
  ],
  "author": "shayon",
  "license": "ISC",
  "devDependencies": {
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-node": "^4.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "aws-sdk": "^2.1693.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.0",
    "multer": "^2.1.0",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.18.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.1",
    "otp-generator": "^4.0.1",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tedious": "^19.2.1",
    "unirest": "^0.6.0"
  }
}
